#!/usr/bin/env bash
# Pre-push gate: when the push would update refs/heads/main, run the fast
# local test suites (dotnet, tsc --noEmit, vitest). Abort the push on first
# failure.
#
# E2E (Playwright) lives in CI — see the rationale block below for why.
#
# Other branches push freely. Set LISTFORGE_SKIP_PREPUSH=1 to bypass in
# emergencies (CI is the authoritative gate either way).

set -u

PROTECTED_REF="refs/heads/main"

pushing_to_main=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "${remote_ref}" = "${PROTECTED_REF}" ]; then
    pushing_to_main=1
  fi
done

if [ "${pushing_to_main}" -eq 0 ]; then
  exit 0
fi

if [ "${LISTFORGE_SKIP_PREPUSH:-0}" = "1" ]; then
  echo "pre-push: LISTFORGE_SKIP_PREPUSH=1 set — skipping local test gate (CI still gates)." >&2
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"

if [ -f /tmp/listforge-env.sh ]; then
  # shellcheck disable=SC1091
  . /tmp/listforge-env.sh
fi

banner() {
  echo
  echo "────────────────────────────────────────────────────────────"
  echo "  $1"
  echo "────────────────────────────────────────────────────────────"
}

fail() {
  local label="$1"
  echo
  echo "✗ pre-push gate failed at: ${label}" >&2
  echo "  Push to main aborted. Fix the failure or re-run with LISTFORGE_SKIP_PREPUSH=1 to bypass." >&2
  exit 1
}

banner "Pre-push gate: pushing to main — running test suites"

banner "Backend  · dotnet test ListForge.sln"
( cd "${repo_root}" && dotnet test ListForge.sln --nologo ) || fail "Backend · dotnet test"

banner "Frontend · typecheck (tsc --noEmit)"
( cd "${repo_root}/frontend" && pnpm exec tsc --noEmit ) || fail "Frontend · typecheck"

banner "Frontend · lint (eslint, includes jsx-a11y)"
( cd "${repo_root}/frontend" && pnpm exec eslint . ) || fail "Frontend · lint"

banner "Frontend · vitest run"
( cd "${repo_root}/frontend" && pnpm exec vitest run ) || fail "Frontend · vitest"

# E2E (Playwright) runs by default. The axe-core/playwright a11y spec lives
# here, so skipping E2E means a11y violations only get caught in CI — slower
# feedback and a wider blast radius if you forget to wait for green.
# Opt out with LISTFORGE_SKIP_PREPUSH_E2E=1 on machines where Chromium system
# libraries (libglib, libnss, …) aren't installed (some dev containers /
# Codespaces). CI is the authoritative gate either way.
if [ "${LISTFORGE_SKIP_PREPUSH_E2E:-0}" = "1" ]; then
  echo "pre-push: LISTFORGE_SKIP_PREPUSH_E2E=1 set — skipping E2E (CI still gates)." >&2
else
  banner "E2E      · playwright test (includes a11y.spec.ts)"
  playwright_bin="${repo_root}/frontend/node_modules/.bin/playwright"
  if [ ! -x "${playwright_bin}" ]; then
    ( cd "${repo_root}/frontend" && pnpm install --frozen-lockfile ) || fail "E2E · pnpm install"
  fi
  ( cd "${repo_root}/frontend" && "${playwright_bin}" install chromium ) || fail "E2E · playwright install chromium"
  ( cd "${repo_root}/frontend" && "${playwright_bin}" test ) || fail "E2E · playwright"
fi

echo
echo "✓ All suites passed — push to main allowed."
exit 0

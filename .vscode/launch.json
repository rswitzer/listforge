{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (ListForge.API)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-backend",
      "program": "${workspaceFolder}/src/ListForge.API/bin/Debug/net9.0/ListForge.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/ListForge.API",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://0.0.0.0:5050"
      }
    },
    {
      "name": "Frontend (Vite dev server)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Run Backend + Frontend",
      "configurations": ["Backend (ListForge.API)", "Frontend (Vite dev server)"],
      "stopAll": true
    }
  ]
}

{
  "name": "ListForge",
  "dockerComposeFile": "../compose.yaml",
  "service": "workspace",
  "workspaceFolder": "/workspaces/listforge",
  "shutdownAction": "stopCompose",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "overrideFeatureInstallOrder": [
    "ghcr.io/devcontainers/features/git",
    "ghcr.io/devcontainers/features/docker-outside-of-docker",
    "ghcr.io/devcontainers/features/node"
  ],

  "forwardPorts": [5050, 5173],
  "portsAttributes": {
    "5050": {
      "label": "ListForge API",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Vite (Frontend)",
      "onAutoForward": "openPreview"
    }
  },

  "onCreateCommand": ".devcontainer/fix-volume-ownership.sh",
  "postCreateCommand": ".devcontainer/post-create.sh",
  "updateContentCommand": "(cd frontend && pnpm install --frozen-lockfile=false) && (cd frontend && pnpm exec playwright install chromium)",
  "postStartCommand": ".devcontainer/ensure-claude.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "vitest.explorer",
        "ms-playwright.playwright",
        "EditorConfig.EditorConfig"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "[csharp]": {
          "editor.tabSize": 4
        },
        "files.eol": "\n",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "remoteUser": "vscode"
}

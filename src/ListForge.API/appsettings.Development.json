{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Auth": {
    "Issuer": "ListForge",
    "Audience": "listforge-api",
    "JwtSecret": "set-via-user-secrets",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14
  },
  "Database": {
    "ConnectionString": "Host=postgres;Port=5432;Database=listforge;Username=listforge;Password=listforge"
  },
  "Storage": {
    "RootPath": ".local-storage"
  },
  "Frontend": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  }
}
